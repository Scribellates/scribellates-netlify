<section class="oeuvres-grid-section">
  <div class="oeuvres-search-wrapper">
    <input
      type="search"
      id="oeuvres-search"
      class="oeuvres-search-input"
      placeholder="Rechercher une œuvre ou un auteur…"
      aria-label="Rechercher une œuvre ou un auteur"
    />
    <div class="oeuvres-filter-group" role="group" aria-label="Filtrer par statut">
      <button class="oeuvres-filter-btn oeuvres-filter-btn--active" data-filter="">Tous</button>
      <button class="oeuvres-filter-btn" data-filter="terminé">Terminé</button>
      <button class="oeuvres-filter-btn" data-filter="en-cours">En cours</button>
      <button class="oeuvres-filter-btn" data-filter="réécriture">Réécriture</button>
    </div>
  </div>
  <h1 class="oeuvres-grid-title">Oeuvres</h1>
  <div class="card-grid" id="oeuvres-card-grid">
    {% for oeuvre in collections.oeuvres %}
    {% set auteurNom = oeuvre.data.auteur.nom or oeuvre.data.auteur %}
    <a href="{{ oeuvre.url }}" class="card card-oeuvre card-oeuvre--grid"
         data-titre="{{ oeuvre.data.titre | lower }}"
         data-auteur="{{ auteurNom | lower }}"
         data-statut="{{ oeuvre.data.statut | replace(' ', '-') | lower }}">
      <img class="card-oeuvre-image card-oeuvre-image--grid" src="{{ oeuvre.data.image }}" alt="Couverture de {{ oeuvre.data.titre }}" />
      <div class="card-oeuvre-body">
        <h3 class="card-oeuvre-titre">{{ oeuvre.data.titre }}</h3>
        <p class="card-oeuvre-auteur">{{ auteurNom }}</p>
        <p class="card-oeuvre-extrait">{{ oeuvre.data.description }}</p>
        <span class="card-oeuvre-statut card-oeuvre-statut--{{ oeuvre.data.statut | replace(' ', '-') | lower }}">{{ oeuvre.data.statut }}</span>
      </div>
    </a>
    {% endfor %}
  </div>
  <p class="oeuvres-no-results" id="oeuvres-no-results" hidden>Aucun résultat.</p>
</section>

<script>
  (function () {
    const input = document.getElementById('oeuvres-search');
    const cards = document.querySelectorAll('#oeuvres-card-grid .card-oeuvre--grid');
    const noResults = document.getElementById('oeuvres-no-results');
    const filterBtns = document.querySelectorAll('.oeuvres-filter-btn');
    let activeFilter = '';

    function applyFilters() {
      const query = input.value.toLowerCase().trim();
      let visible = 0;

      cards.forEach(function (card) {
        const matchQuery =
          card.dataset.titre.includes(query) ||
          card.dataset.auteur.includes(query);
        const matchFilter =
          activeFilter === '' || card.dataset.statut === activeFilter;
        const show = matchQuery && matchFilter;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      noResults.hidden = visible > 0;
    }

    input.addEventListener('input', applyFilters);

    filterBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        filterBtns.forEach(function (b) { b.classList.remove('oeuvres-filter-btn--active'); });
        btn.classList.add('oeuvres-filter-btn--active');
        activeFilter = btn.dataset.filter;
        applyFilters();
      });
    });
  })();
</script>
