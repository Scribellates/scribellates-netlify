<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title or "Scribellates" }}</title>
  <style>
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: sans-serif;
    }

    /* ── Navbar ── */
    nav {
      display: flex;
      align-items: center;
      gap: 3rem;
      padding: 1rem 2rem;
      background-color: #fff;
      border-bottom: 1px solid #e5e5e5;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo {
      display: flex;
      align-items: center;
      text-decoration: none;
      flex-shrink: 0;
    }

    .nav-logo img {
      height: 40px;
      width: auto;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2.5rem;
      list-style: none;
    }

    .nav-links a {
      text-decoration: none;
      color: #222;
      font-size: 1rem;
      font-weight: 500;
      letter-spacing: 0.02em;
      transition: color 0.2s;
    }

    .nav-links a:hover {
      color: #6b48ff;
    }

    /* ── Contenu principal ── */
    main {
      padding: 2rem;
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">
      <img src="/images/logo_couleur_texte.png" alt="Scribellates logo" />
    </a>

    <ul class="nav-links">
      <li><a href="/">Oeuvres</a></li>
      <li><a href="/a-propos/">Auteurs</a></li>
      <li><a href="/portfolio/">Actualités</a></li>
      <li><a href="/contact/">Nous rejoindre</a></li>
    </ul>
  </nav>

  <main>
    {{ content | safe }}
  </main>

</body>
</html>
